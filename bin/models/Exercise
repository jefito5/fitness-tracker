
package models;

public class Exercise {
   private int id;
   private String exerciseName;
   private double calorieburn;

   public Exercise(int id, String exerciseName, double calorieburn) {
    this.id = id;
    this.exerciseName = exerciseName;
    this.calorieburn = calorieburn;
   }

   public int getId() {
      return this.id;
   }

   public void setId(int id) {
      this.id = id;
   }

   public String getExerciseName() {
      return this.exerciseName;
   }

   public void setExerciseName(String exerciseName) {
      this.exerciseName = exerciseName;
   }

   public double getCalorieburn() {
      return this.calorieburn;
   }

   public void setCalorieburn(double calorieburn) {
      this.calorieburn = calorieburn;
   }
}
